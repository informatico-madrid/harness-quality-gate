{
    "name": "quality-gate/php-pure-pass",
    "description": "E2E fixture: pure-pass repo for full 5-layer PHP pipeline smoke tests",
    "type": "project",
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "infection/infection": "^0.29",
        "phpstan/phpstan": "^2.0",
        "phpstan/extension-installer": "^1.4",
        "phpmd/phpmd": "^2.15",
        "symplify/easy-coding-standard": "^12.5",
        "rector/rector": "^2.1",
        "friendsofphp/php-cs-fixer": "^3.68",
        "vimeo/psalm": "^6.0"
    },
    "autoload": {
        "psr-4": {
            "Calculator\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CalculatorTest\\": "tests/"
        }
    },
    "config": {
        "bin-dir": "bin",
        "allow-plugins": {
            "infection/extension-installer": true,
            "phpstan/extension-installer": true,
            "symplify/easy-coding-standard/plugin": true
        }
    }
}
