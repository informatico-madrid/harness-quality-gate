{
    "name": "e2e/symfony-mini",
    "description": "Minimal Symfony skeleton for E2E gate testing",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "symfony/framework-bundle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    }
}
